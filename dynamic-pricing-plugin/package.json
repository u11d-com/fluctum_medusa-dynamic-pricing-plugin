{
  "name": "@u11d/medusa-dynamic-pricing",
  "version": "0.1.0",
  "description": "Fluctum — dynamic pricing plugin for Medusa v2 — real-time precious metals pricing via SSE, checkout price locks, and admin pricing-rule management.",
  "author": "u11d <hello@u11d.com> (https://u11d.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/u11d-com/fluctum_medusa-dynamic-pricing-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/u11d-com/fluctum_medusa-dynamic-pricing-plugin/issues"
  },
  "homepage": "https://fluctum.io",
  "license": "MIT",
  "files": [
    ".medusa/server"
  ],
  "exports": {
    ".": {
      "types": "./.medusa/server/src/index.d.ts",
      "default": "./.medusa/server/src/index.js"
    },
    "./client": {
      "types": "./.medusa/server/src/client.d.ts",
      "default": "./.medusa/server/src/client.js"
    },
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./jobs/fetch-spot-prices": "./.medusa/server/src/jobs/fetch-spot-prices.js",
    "./modules/dynamic-pricing": "./.medusa/server/src/modules/dynamic-pricing/index.js",
    "./.medusa/server/src/modules/dynamic-pricing": "./.medusa/server/src/modules/dynamic-pricing/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": {
      "types": "./.medusa/server/src/*.d.ts",
      "default": "./.medusa/server/src/*.js"
    },
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2",
    "dynamic-pricing",
    "precious-metals",
    "gold",
    "silver",
    "sse",
    "checkout-price-lock"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@medusajs/test-utils": "2.17.2",
    "@medusajs/ui": "4.1.19",
    "@medusajs/icons": "2.17.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.4.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/test-utils": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@medusajs/ui": "4.1.19",
    "@medusajs/icons": "2.17.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.2"
}
