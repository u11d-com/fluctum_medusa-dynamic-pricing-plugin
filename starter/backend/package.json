{
  "name": "@u11d/medusa-dynamic-pricing-backend",
  "version": "0.0.1",
  "description": "Medusa backend for precious metals dynamic pricing.",
  "author": "u11d",
  "license": "MIT",
  "keywords": [
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "migrate": "medusa db:migrate",
    "seed": "medusa db:migrate",
    "create-admin": "npx medusa user --email admin@admin.com --password admin",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --passWithNoTests",
    "test:integration": "npm run test:pricing-rules && npm run test:sse && npm run test:checkout-flow",
    "test:checkout-flow": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --testPathPattern=checkout-flow",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:pricing-rules": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --testPathPattern=pricing-rules",
    "test:sse": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit --testPathPattern=sse-spot-prices"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.2",
    "@medusajs/admin-shared": "2.15.2",
    "@medusajs/caching": "2.15.2",
    "@medusajs/cli": "2.15.2",
    "@medusajs/dashboard": "2.15.2",
    "@medusajs/draft-order": "2.15.2",
    "@medusajs/framework": "2.15.2",
    "@medusajs/medusa": "2.15.2",
    "@medusajs/ui": "4.1.12",
    "@tanstack/react-query": "5.64.2",
    "@u11d/medusa-dynamic-pricing": "file:.yalc/@u11d/medusa-dynamic-pricing",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.17.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.6.2"
}
