{
  "name": "dynamic-pricing",
  "private": false,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm -r dev",
    "build": "npm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm --workspaces --if-present run test:unit",
    "test:integration": "npm -w @dtc/backend run test:integration",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**",
    "dynamic-pricing-plugin"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  },
  "dependencies": {
    "@u11d/dynamic-pricing-plugin": "file:.yalc/@u11d/dynamic-pricing-plugin"
  }
}
