{
  "name": "dynamic-pricing",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@dtc/backend --filter=@dtc/storefront --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm --workspaces --if-present run test:unit",
    "test:integration": "npm -w @dtc/backend run test:integration",
    "backend:migrate": "npm -w @dtc/backend run migrate",
    "backend:seed": "npm -w @dtc/backend run seed",
    "backend:dev": "npm -w @dtc/backend run dev",
    "backend:create-admin": "npm -w @dtc/backend run create-admin",
    "storefront:dev": "npm -w @dtc/storefront run dev",
    "storefront:check": "npm -w @dtc/storefront run check",
    "plugin:build": "npm -w @u11d/dynamic-pricing-plugin run build && npx --yes yalc push"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**",
    "dynamic-pricing-plugin"
  ],
  "overrides": {
    "@types/react": "19.0.5",
    "@types/react-dom": "19.0.5",
    "ajv": "^8.0.0"
  },
  "dependencies": {
    "@u11d/dynamic-pricing-plugin": "file:.yalc/@u11d/dynamic-pricing-plugin"
  }
}
