{
  "name": "dynamic-pricing",
  "description": "Fluctum — dynamic pricing solution for Medusa",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@u11d/medusa-dynamic-pricing-backend --filter=@u11d/medusa-dynamic-pricing-storefront --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm --workspaces --if-present run test:unit",
    "test:integration": "npm -w @u11d/medusa-dynamic-pricing-backend run test:integration",
    "backend:migrate": "npm -w @u11d/medusa-dynamic-pricing-backend run migrate",
    "backend:seed": "npm -w @u11d/medusa-dynamic-pricing-backend run seed",
    "db:reset": "./reset-db.sh",
    "backend:dev": "npm -w @u11d/medusa-dynamic-pricing-backend run dev",
    "backend:create-admin": "npm -w @u11d/medusa-dynamic-pricing-backend run create-admin",
    "storefront:dev": "npm -w @u11d/medusa-dynamic-pricing-storefront run dev",
    "storefront:check": "npm -w @u11d/medusa-dynamic-pricing-storefront run check",
    "plugin:build": "npm -w @u11d/medusa-dynamic-pricing run build && cd dynamic-pricing-plugin && npx --yes yalc push"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**",
    "!apps/backend/.yalc/**",
    "dynamic-pricing-plugin"
  ],
  "overrides": {
    "@types/react": "19.0.5",
    "@types/react-dom": "19.0.5",
    "ajv": "^8.0.0"
  },
  "dependencies": {
    "@u11d/medusa-dynamic-pricing": "file:.yalc/@u11d/medusa-dynamic-pricing"
  }
}
